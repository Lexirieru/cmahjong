# Deployer (juga owner/house default). JANGAN commit .env asli.
PRIVATE_KEY=0xabc...

# RPC. Mainnet: https://forno.celo.org  |  Testing pakai Alfajores via --rpc-url alfajores
CELO_RPC=https://forno.celo.org

# API key Celoscan (Etherscan v2 multichain) untuk verifikasi kontrak.
ETHERSCAN_API_KEY=your_celoscan_api_key

# Opsional — dibaca DeployMahjongTable.s.sol:
# STABLE_TOKEN=0x...     # default: cUSD mainnet
# RAKE_BPS=300           # house cut, default 3%
