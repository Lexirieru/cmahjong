# Deployer (also the default owner/house). DO NOT commit the real .env.
PRIVATE_KEY=0xabc...

# RPC. Mainnet: https://forno.celo.org  |  For testing use Alfajores via --rpc-url alfajores
CELO_RPC=https://forno.celo.org

# Celoscan API key (Etherscan v2 multichain) for contract verification.
ETHERSCAN_API_KEY=your_celoscan_api_key

# Optional — read by DeployMahjongTable.s.sol:
# STABLE_TOKEN=0x...     # default: cUSD mainnet
# RAKE_BPS=300           # house cut, default 3%
