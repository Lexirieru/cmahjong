// Postgres schema for the cMahjong backend.
// Stores an on-chain game mirror + commit/reveal + round log.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  OPEN // waiting for players + commit
  REVEALING // waiting for reveal
  PLAYING // game in progress
  SETTLED // already settled on-chain
  CANCELLED
}

/// Mirror of a game in the MahjongTable contract (per on-chain gameId).
model GameTable {
  id            String      @id @default(cuid())
  chainGameId   String      @unique // on-chain gameId (uint256 as a string)
  token         String // buy-in token address (0x0 = CELO native)
  buyIn         String // smallest token unit (string for precision)
  server        String // server/operator address
  status        TableStatus @default(OPEN)
  length        String      @default("hanchan") // "east" | "hanchan"
  seed          String? // collective seed after full reveal
  liveState     Json? // live Hanchan/Round snapshot (to resume after a restart)
  finalRanking  String[] // addresses of places 1..4 at settle time
  serverSig     String? // server signature (settleByServer)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  seats Seat[]
  moves Move[]
}

/// A single player seat at a table.
model Seat {
  id         String  @id @default(cuid())
  table      GameTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId    String
  seatIndex  Int // 0..3 (join order = E,S,W,N relative to the dealer)
  address    String // player wallet address
  commitment String? // keccak256(gameId, player, secret)
  revealed   Boolean @default(false)
  finalPoints Int?

  @@unique([tableId, seatIndex])
  @@unique([tableId, address])
}

/// Log of every action (for audit & step-by-step replay).
model Move {
  id        String   @id @default(cuid())
  table     GameTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId   String
  seq       Int // order within the game (for deterministic replay)
  seatIndex Int
  kind      String // discard | riichi | tsumo | pon | chi | kan | ron | pass
  payload   Json?
  createdAt DateTime @default(now())

  @@unique([tableId, seq])
  @@index([tableId, seq])
}
