// Skema Postgres untuk cMahjong backend.
// Menyimpan mirror game on-chain + commit/reveal + log ronde.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  OPEN // menunggu pemain + commit
  REVEALING // menunggu reveal
  PLAYING // game berjalan
  SETTLED // sudah settle on-chain
  CANCELLED
}

/// Mirror sebuah game di kontrak MahjongTable (per gameId on-chain).
model GameTable {
  id            String      @id @default(cuid())
  chainGameId   String      @unique // gameId on-chain (uint256 sebagai string)
  token         String // alamat token buy-in (0x0 = CELO native)
  buyIn         String // satuan terkecil token (string untuk presisi)
  server        String // alamat server/operator
  status        TableStatus @default(OPEN)
  seed          String? // seed kolektif setelah reveal lengkap
  liveState     Json? // snapshot Hanchan/Round live (untuk resume setelah restart)
  finalRanking  String[] // alamat juara 1..4 saat settle
  serverSig     String? // tanda tangan server (settleByServer)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  seats Seat[]
  moves Move[]
}

/// Satu kursi (seat) pemain di sebuah meja.
model Seat {
  id         String  @id @default(cuid())
  table      GameTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId    String
  seatIndex  Int // 0..3 (urutan join = E,S,W,N relatif dealer)
  address    String // alamat wallet pemain
  commitment String? // keccak256(gameId, player, secret)
  revealed   Boolean @default(false)
  finalPoints Int?

  @@unique([tableId, seatIndex])
  @@unique([tableId, address])
}

/// Log tiap aksi (untuk audit & replay langkah-demi-langkah).
model Move {
  id        String   @id @default(cuid())
  table     GameTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  tableId   String
  seq       Int // urutan dalam game (untuk replay deterministik)
  seatIndex Int
  kind      String // discard | riichi | tsumo | pon | chi | kan | ron | pass
  payload   Json?
  createdAt DateTime @default(now())

  @@unique([tableId, seq])
  @@index([tableId, seq])
}
